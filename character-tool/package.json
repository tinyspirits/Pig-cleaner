{
  "name": "character-tool",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "main.js",
  "scripts": {
    "dev": "concurrently \"vite --port 5174\" \"wait-on http://localhost:5174 && electron .\"",
    "build": "tsc && vite build",
    "build:electron": "npm run build && electron-builder",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.tiny.charactermaker",
    "productName": "Character Maker Tool",
    "directories": {
      "output": "../release"
    },
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        "dmg"
      ],
      "icon": "public/favicon.png"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/favicon.png"
    }
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.4",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^43.2.0",
    "electron-builder": "^26.15.3",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "wait-on": "^9.1.0"
  },
  "dependencies": {
    "@imgly/background-removal": "^1.7.0",
    "file-saver": "^2.0.5",
    "i18next": "^26.3.6",
    "jszip": "^3.10.1",
    "lucide-react": "^1.25.0",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "react-easy-crop": "^6.2.2",
    "react-i18next": "^17.0.10"
  }
}
