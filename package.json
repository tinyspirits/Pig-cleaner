{
  "name": "pig-cleaner",
  "version": "1.0.0",
  "description": "🐷 Heo Ăn Rác - Desktop pig pet that cleans your Mac",
  "main": "src/main/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:main\"",
    "dev:renderer": "vite",
    "dev:main": "wait-on http://localhost:5173 && electron .",
    "build": "vite build && electron-builder",
    "start": "electron ."
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "i18next": "^26.3.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^17.0.9"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.5.2",
    "concurrently": "^9.2.0",
    "electron": "^43.1.0",
    "electron-builder": "^24.13.3",
    "vite": "^7.0.4",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.pig.cleaner",
    "artifactName": "${name}-${version}-nightly-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/renderer/**/*",
      "src/main/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "src/renderer/assets/tray-icon.png",
        "to": "assets/tray-icon.png"
      },
      {
        "from": "src/renderer/assets/duck-tray-icon.png",
        "to": "assets/duck-tray-icon.png"
      }
    ],
    "mac": {
      "extendInfo": {
        "LSUIElement": true
      },
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "win": {
      "target": "nsis"
    }
  }
}
